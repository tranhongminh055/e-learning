<Window x:Class="StudentMonitor.Views.StudentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="E-Learning - Giao diện Sinh viên"
        Width="1200" Height="750"
        WindowStartupLocation="CenterScreen"
        Background="#F0F2F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Bar -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#27AE60" Offset="0"/>
                    <GradientStop Color="#1E8449" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="18" Background="White" Margin="0,0,10,0">
                        <TextBlock Text="🎓" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="E-Learning Student Portal"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="White" FontFamily="Segoe UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Center Status -->
                <TextBlock Grid.Column="1"
                           Text="🟢 Hệ thống sẵn sàng"
                           FontSize="13" FontFamily="Segoe UI"
                           Foreground="#A9DFBF"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <!-- User Info / Logout -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ProfileButton" Background="Transparent" BorderThickness="0" Margin="0,0,14,0" Cursor="Hand" Click="ProfileButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="32" Height="32" Stroke="White" StrokeThickness="1">
                                <Ellipse.Fill>
                                    <ImageBrush x:Name="ProfileAvatarImage" Stretch="UniformToFill"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock x:Name="GreetingText" Text="Xin chào, Sinh viên!"
                                       FontSize="13" FontFamily="Segoe UI"
                                       Foreground="White"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>
                        </StackPanel>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Padding="5">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Content="Đăng xuất"
                            FontSize="12" FontFamily="Segoe UI"
                            Foreground="White" Background="Transparent"
                            BorderBrush="#7DCEA0" BorderThickness="1"
                            Padding="12,5" Cursor="Hand"
                            Click="LogoutButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="Transparent"
                                        BorderBrush="#7DCEA0" BorderThickness="1"
                                        CornerRadius="4" Padding="12,5">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#00000033"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar Panel -->
            <Border Grid.Column="0" Background="White" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,15,0,15">
                        <TextBlock Text="MENU SINH VIÊN" Foreground="#888" FontSize="12" FontWeight="Bold" Margin="20,5,20,10"/>
                        
                        <Button Style="{StaticResource SidebarButtonStyle}" Click="MenuDashboard_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏠" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Trang chủ"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Click="MenuMyExams_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📝" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Bài thi của tôi"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Click="MenuResults_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Kết quả học tập"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Click="MenuFaceAttendance_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Điểm danh khuôn mặt"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButtonStyle}" Click="MenuLesson_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📚" Width="24" TextAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Lesson"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Content Container -->
            <Grid Grid.Column="1" Margin="20">
                <!-- Welcome Panel -->
                <Border x:Name="WelcomePanel" Background="White" CornerRadius="12" Padding="30" Visibility="Visible">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.06"/>
                    </Border.Effect>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                <Image Source="pack://application:,,,/Resources/dtu_logo.png" Width="40" Height="40" Margin="0,0,10,0" Visibility="Collapsed"/>
                                <TextBlock Text="NỘI QUY SỬ DỤNG HỆ THỐNG PORTAL" FontSize="24" FontWeight="Bold" Foreground="#C60000" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <TextBlock Text="Khi sử dụng Hệ thống Portal, mỗi Sinh viên/Học viên phải tuyệt đối tuân thủ các quy định sau:" FontStyle="Italic" FontSize="14" Foreground="#333" Margin="0,0,0,15"/>
                            <TextBlock Text="ĐỐI VỚI SINH VIÊN/HỌC VIÊN:" FontWeight="Bold" FontSize="14" Margin="0,0,0,15" TextDecorations="Underline"/>
                            
                            <TextBlock Text="1. Mọi Sinh viên/Học viên khi tham gia sử dụng hệ thống portal phải chịu trách nhiệm hoàn toàn về sự xác thực và tính chính xác của mọi thông tin mình cập nhật, đăng ký, đăng tải,...;" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22"/>
                            <TextBlock Text="2. Nghiêm cấm mọi hành vi phá hoại hệ thống dưới mọi hình thức, khiến hệ thống không tiếp tục hoạt động, bằng các tiểu xảo kỹ thuật hay bằng những thông tin sai lệch;" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22">
                                <Run Text="3. Mỗi Sinh viên/Học viên có trách nhiệm quản lý thông tin tài khoản, mật khẩu đăng nhập và "/>
                                <Run Text="Mã số Sinh viên/Học viên" FontWeight="Bold" Foreground="Red"/>
                                <Run Text=" của mình. Không được tiết lộ thông tin tài khoản cá nhân của mình cho bất kỳ một cá nhân hay tổ chức nào khác;"/>
                            </TextBlock>
                            <TextBlock Text="4. Sinh viên/Học viên chịu hoàn toàn trách nhiệm về các hành vi thực hiện thông qua tài khoản của mình nếu để lộ thông tin (đăng nhập) tài khoản cá nhân." TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22"/>
                            <TextBlock Text="5. Nghiêm cấm hành vi dùng Email trường cấp (...@dtu.edu.vn) cho các mục đích spam hay phát tán thông tin sai lệch, đồi trụy hoặc phản động;" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22">
                                <Run Text="6. Không được sử dụng các hình ảnh dễ gây hiểu nhầm, kinh dị, đồi trụy, phản động hay trái với thuần phong mỹ tục của người Việt Nam cho "/>
                                <Run Text="Avatar" FontWeight="Bold"/>
                                <Run Text=" (hình ảnh biểu trưng) của tài khoản cá nhân."/>
                            </TextBlock>
                            <TextBlock Text="7. Kích thước Avatar không được quá 130 x 130 pixel (hay 3,67cm x 3,67cm) và dung lượng không được lớn hơn 150 KB;" TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22"/>
                            <TextBlock Text="8. Sinh viên/Học viên ở học kỳ đầu (hay trong một số trường hợp, ở năm đầu) phải tuân thủ việc phân bổ môn học của nhà trường." TextWrapping="Wrap" Margin="0,0,0,12" FontSize="14" LineHeight="22"/>

                            <!-- Clock Panel -->
                            <Border CornerRadius="12" Padding="30,20" Margin="0,30,0,0" HorizontalAlignment="Center" MinWidth="450">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#D02040" Offset="0"/>
                                        <GradientStop Color="#A01030" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel HorizontalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                                        <!-- Hours -->
                                        <Border Background="#EAEAEA" CornerRadius="6" Padding="12,5" Margin="0,0,5,0" BorderBrush="#999" BorderThickness="1,1,2,2">
                                            <TextBlock x:Name="ClockHours" Text="00" FontSize="42" FontWeight="Bold" Foreground="#900000" FontFamily="Arial" FontStyle="Italic"/>
                                        </Border>
                                        <TextBlock Text=":" FontSize="42" FontWeight="Bold" Foreground="White" Margin="5,-5,5,0" VerticalAlignment="Center"/>
                                        
                                        <!-- Minutes -->
                                        <Border Background="#EAEAEA" CornerRadius="6" Padding="12,5" Margin="5,0" BorderBrush="#999" BorderThickness="1,1,2,2">
                                            <TextBlock x:Name="ClockMinutes" Text="00" FontSize="42" FontWeight="Bold" Foreground="#900000" FontFamily="Arial" FontStyle="Italic"/>
                                        </Border>
                                        <TextBlock Text=":" FontSize="42" FontWeight="Bold" Foreground="White" Margin="5,-5,5,0" VerticalAlignment="Center"/>
                                        
                                        <!-- Seconds -->
                                        <Border Background="#EAEAEA" CornerRadius="6" Padding="12,5" Margin="5,0,0,0" BorderBrush="#999" BorderThickness="1,1,2,2">
                                            <TextBlock x:Name="ClockSeconds" Text="00" FontSize="42" FontWeight="Bold" Foreground="#900000" FontFamily="Arial" FontStyle="Italic"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock x:Name="ClockDate" Text="Chủ nhật, ngày 14 tháng 6 năm 2026" FontSize="20" Foreground="White" HorizontalAlignment="Center" FontFamily="Segoe UI"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- Lesson Panel -->
                <Border x:Name="LessonPanel" Background="#36393F" CornerRadius="12" Visibility="Collapsed">
                    <Border.Resources>
                        <Style x:Key="SubjectButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="#2F3136"/>
                            <Setter Property="Foreground" Value="#D4D4D5"/>
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="Padding" Value="20,15"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#40444B"/>
                                    <Setter Property="Foreground" Value="White"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Resources>
                    
                    <Grid>
                        <!-- Subject List View -->
                        <Grid x:Name="LessonSubjectListView" Visibility="Visible">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="30">
                                    <TextBlock Text="Học Kỳ Hè - Năm Học 2025-2026" Foreground="#E0E0E0" FontSize="26" FontWeight="Bold" Margin="0,0,0,20"/>
                                    <Border BorderBrush="#202225" BorderThickness="0,1,0,0" Margin="0,0,0,20"/>
                                    
                                    <Button Content="CMU-SE 433 SGIS (2026SU)" Style="{StaticResource SubjectButtonStyle}" Click="Subject_Click"/>
                                    <Button Content="HIS 222 SO (2026SU)" Style="{StaticResource SubjectButtonStyle}" Click="Subject_Click"/>
                                    <Button Content="IS-CS 466 SCIS (2026SU)" Style="{StaticResource SubjectButtonStyle}" Click="Subject_Click"/>
                                    <Button Content="POS 351 SG (2026SU)" Style="{StaticResource SubjectButtonStyle}" Click="Subject_Click"/>
                                    <Button Content="POS 361 SO (2026SU)" Style="{StaticResource SubjectButtonStyle}" Click="Subject_Click"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <!-- Subject Detail View -->
                        <Grid x:Name="LessonDetailView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <!-- Header Red bar -->
                            <Border Background="#CC0000" Padding="15" CornerRadius="12,12,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🔙" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="18" Margin="0,0,15,0" Click="BackToSubjectList_Click" Cursor="Hand"/>
                                    <TextBlock x:Name="DetailSubjectTitle" Text="IS-CS 466 SCIS (2026SU) &gt; Resources" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="#2F3136" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="Site Resources" Foreground="White" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid for Resources -->
                            <DataGrid x:Name="LessonDataGrid" Grid.Row="2" Background="#36393F" Foreground="#D4D4D5" RowBackground="#36393F" AlternatingRowBackground="#2F3136" AutoGenerateColumns="False" HeadersVisibility="Column" BorderThickness="0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#202225" CanUserAddRows="False">
                                <DataGrid.Resources>
                                    <Style TargetType="DataGridColumnHeader">
                                        <Setter Property="Background" Value="#202225"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Padding" Value="10,8"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </DataGrid.Resources>
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="3*"/>
                                    <DataGridTextColumn Header="Access" Binding="{Binding Access}" Width="*"/>
                                    <DataGridTextColumn Header="Created By" Binding="{Binding UploadedBy}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Modified" Binding="{Binding UploadDate}" Width="1.5*"/>
                                    <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="*"/>
                                    
                                    <!-- Action Button -->
                                    <DataGridTemplateColumn Header="" Width="100">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Actions ▾" Background="#CC0000" Foreground="White" BorderThickness="0" Padding="8,4" Cursor="Hand" Click="RowActions_Click">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Mở bài giảng (Học trực tiếp)" Click="OpenLesson_Click"/>
                                                            <MenuItem Header="Download bài giảng" Click="DownloadLesson_Click"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                </Button>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Lesson Content View (Học trực tiếp) -->
                        <Grid x:Name="LessonContentView" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <Border Background="#CC0000" Padding="15" CornerRadius="12,12,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="🔙" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="18" Margin="0,0,15,0" Click="BackToLessonDetail_Click" Cursor="Hand"/>
                                    <TextBlock x:Name="LessonContentTitle" Text="Nội dung bài giảng" Foreground="White" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Background="White">
                                <wv2:WebView2 x:Name="LessonWebView"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- My Exams Panel -->
                <Border x:Name="MyExamsPanel" Background="White" CornerRadius="12" Padding="30" Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Bài Thi Của Tôi" Foreground="#333" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Text="Danh sách các bài thi bạn cần hoàn thành." Foreground="#555" FontSize="14" Margin="0,0,0,20"/>

                        <DataGrid x:Name="MyExamsDataGrid" Grid.Row="2" AutoGenerateColumns="False" HeadersVisibility="Column" Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9" BorderThickness="1" BorderBrush="#D0D0D0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridRow">
                                    <EventSetter Event="MouseDoubleClick" Handler="DataGridRow_MouseDoubleClick"/>
                                </Style>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F5F7FA"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#555"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tên bài thi" Binding="{Binding Title}" Width="2*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#007ACC"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Mô tả" Binding="{Binding Description}" Width="2*"/>
                                <DataGridTextColumn Header="Thời gian mở" Binding="{Binding OpenDate}" Width="1.5*"/>
                                <DataGridTextColumn Header="Hạn nộp (Deadline)" Binding="{Binding DueDate}" Width="1.5*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#D9534F"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Hành động" Width="100">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="Làm bài" Background="#27AE60" Foreground="White" BorderThickness="0" Padding="10,5" Cursor="Hand" Click="StartExam_Click" PreviewMouseLeftButtonDown="StartExam_PreviewMouseLeftButtonDown">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="4"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Take Exam Panel -->
                <Border x:Name="TakeExamPanel" Background="#1A1D20" CornerRadius="12" Visibility="Collapsed" ClipToBounds="True">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="60"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="80"/>
                        </Grid.RowDefinitions>
                        
                        <!-- Header DTU -->
                        <Border Grid.Row="0" Background="#C60000">
                            <Grid Margin="20,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <TextBlock Text="DUY TÂN UNIVERSITY" FontSize="20" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TakeExamTitle" Text=" - Bài thi" FontSize="16" Foreground="#FFD0D0" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="Thời gian còn lại: " FontSize="16" Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TimerTextBlock" Text="00:00:00" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        
                        <!-- Questions -->
                        <ScrollViewer Grid.Row="1" PanningMode="VerticalOnly" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="QuestionsItemsControl" Margin="40,30,40,30">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,40">
                                            <!-- Blockquote style for the question -->
                                            <Border Background="#2C2F33" BorderBrush="#555555" BorderThickness="4,0,0,0" Padding="15" Margin="0,0,0,20">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Id, StringFormat='Câu {0}:'}" Foreground="#FFFFFF" FontSize="18" FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,5"/>
                                                    <TextBlock Text="{Binding Text}" Foreground="#E0E0E0" FontSize="18" FontFamily="Segoe UI" TextWrapping="Wrap" LineHeight="24"/>
                                                </StackPanel>
                                            </Border>
                                            
                                            <!-- Trắc nghiệm options -->
                                            <ItemsControl ItemsSource="{Binding Options}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <RadioButton Content="{Binding}" Foreground="#CCCCCC" FontSize="16" FontFamily="Segoe UI" Margin="0,0,0,15" Tag="{Binding DataContext.Id, RelativeSource={RelativeSource AncestorType=ItemsControl}}" GroupName="{Binding DataContext.Id, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                                            <RadioButton.Style>
                                                                <Style TargetType="RadioButton">
                                                                    <Setter Property="Template">
                                                                        <Setter.Value>
                                                                            <ControlTemplate TargetType="RadioButton">
                                                                                <StackPanel Orientation="Horizontal" Background="Transparent">
                                                                                    <Border Width="20" Height="20" CornerRadius="10" BorderBrush="#888" BorderThickness="2" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                                        <Ellipse x:Name="CheckMark" Width="10" Height="10" Fill="#C60000" Visibility="Collapsed"/>
                                                                                    </Border>
                                                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                                                </StackPanel>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </Setter.Value>
                                                                    </Setter>
                                                                </Style>
                                                            </RadioButton.Style>
                                                        </RadioButton>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            
                                            <!-- Tự luận/Câu hỏi ngắn (Text input) -->
                                            <TextBox x:Name="AnswerTextBox" Background="#2B3035" Foreground="White" BorderBrush="#495057" FontSize="16" Padding="15" TextWrapping="Wrap" AcceptsReturn="True" Height="120" Tag="{Binding Id}">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Options}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        
                        <!-- Footer -->
                        <Border Grid.Row="2" Background="#212529" BorderBrush="#343A40" BorderThickness="0,1,0,0">
                            <Button Content="Nộp bài &amp; Chấm điểm" Width="220" Height="45" Background="#27AE60" Foreground="White" FontWeight="Bold" FontSize="16" Cursor="Hand" Click="SubmitExam_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- Study Results Panel -->
                <Border x:Name="StudyResultsPanel" Background="White" CornerRadius="12" Padding="30" Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Kết Quả Học Tập" Foreground="#333" FontSize="22" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Grid.Row="1" Text="Danh sách điểm và nhận xét từ AI cho các bài thi đã nộp." Foreground="#555" FontSize="14" Margin="0,0,0,20"/>

                        <DataGrid x:Name="ResultsDataGrid" Grid.Row="2" AutoGenerateColumns="False" HeadersVisibility="Column" Background="White" RowBackground="White" AlternatingRowBackground="#F9F9F9" BorderThickness="1" BorderBrush="#D0D0D0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#EEEEEE" CanUserAddRows="False" IsReadOnly="True">
                            <DataGrid.Resources>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="#F5F7FA"/>
                                    <Setter Property="Foreground" Value="#333"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                    <Setter Property="BorderThickness" Value="0,0,1,1"/>
                                </Style>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Foreground" Value="#555"/>
                                    <Setter Property="Padding" Value="10,8"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="{x:Type DataGridCell}">
                                                <Border Padding="{TemplateBinding Padding}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                                    <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Bài thi" Binding="{Binding AssignmentTitle}" Width="1.5*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#007ACC"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Điểm (AI chấm)" Binding="{Binding Score}" Width="100">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="Foreground" Value="#C60000"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Nhận xét" Binding="{Binding Feedback}" Width="3*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Ngày nộp" Binding="{Binding SubmittedAt}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Face Attendance Panel -->
                <Border x:Name="FaceAttendancePanel" Background="White" CornerRadius="12" Padding="0" Visibility="Collapsed" ClipToBounds="True">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" BlurRadius="15" ShadowDepth="3" Opacity="0.06"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#F8F9FA" Padding="20,15">
                            <StackPanel>
                                <TextBlock Text="🔐 Điểm danh Khuôn mặt AI" FontSize="20" FontWeight="Bold" Foreground="#333"/>
                                <TextBlock Text="Hệ thống sử dụng trí tuệ nhân tạo (Face Recognition) để xác thực danh tính của bạn" FontSize="12" Foreground="#888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <wv2:WebView2 x:Name="FaceAttendanceWebView" Grid.Row="1"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
