<Window x:Class="StudentMonitor.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-Learning - Đăng ký tài khoản"
        Width="480" Height="740"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundGrayBrush}">

    <Grid>
        <Grid.RowDefinitions> <!--chia 3 phan de hien thi noi dung-->
            <RowDefinition Height="Auto"/> <!-- phan 1 la header phan mem-->
            <RowDefinition Height="*"/><!--phan 2 la content-->
            <RowDefinition Height="Auto"/><!--phan 3 la footer phan mem-->
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- HEADER - Blue Banner                         -->
        <!-- ============================================ -->
        <Border Grid.Row="0" Padding="0,24,0,24">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0066B3" Offset="0"/>
                    <GradientStop Color="#004C8C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel HorizontalAlignment="Center">
                <!-- Logo Circle -->
                <Border Width="54" Height="54" CornerRadius="27"
                        Background="White" Margin="0,0,0,10"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid>
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#0066B3" Data="M12,1 L3,5 L3,11 C3,16.55 6.84,21.74 12,23 C17.16,21.74 21,16.55 21,11 L21,5 L12,1 Z"/>
                                <Path Stroke="White" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M8.5,12.5 L11,15 L16,9.5"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Border>

                <TextBlock Text="E-Learning"
                           FontSize="24" FontWeight="Bold"
                           Foreground="White" FontFamily="Segoe UI"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Đăng ký tài khoản mới"
                           FontSize="13" Foreground="#B0D4F1"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ============================================ -->
        <!-- CENTER - Register Form Card                  -->
        <!-- ============================================ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0">
            <Border Background="White"
                    CornerRadius="12"
                    Margin="50,20,50,20"
                    Padding="30,24,30,20"
                    VerticalAlignment="Top">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                </Border.Effect>

                <StackPanel>
                    <!-- Error Message -->
                    <Border x:Name="ErrorBorder" Visibility="Collapsed"
                            Background="#FFF0F0" CornerRadius="6"
                            Padding="12,8" Margin="0,0,0,12"
                            BorderBrush="#FFCCCC" BorderThickness="1">
                        <TextBlock x:Name="ErrorMessage"
                                   Foreground="{StaticResource ErrorRedBrush}"
                                   FontSize="12" FontFamily="Segoe UI"
                                   TextWrapping="Wrap"/>
                    </Border>


                    <!-- Full Name -->
                    <Grid Margin="0,0,0,12">
                        <TextBox x:Name="FullNameTextBox"
                                 Style="{StaticResource LoginTextBoxStyle}"
                                 GotFocus="FullNameTextBox_GotFocus"
                                 LostFocus="FullNameTextBox_LostFocus"/>
                        <TextBlock x:Name="FullNamePlaceholder"
                                   Text="  👤  Họ và tên"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Email -->
                    <Grid Margin="0,0,0,12">
                        <TextBox x:Name="EmailTextBox"
                                 Style="{StaticResource LoginTextBoxStyle}"
                                 GotFocus="EmailTextBox_GotFocus"
                                 LostFocus="EmailTextBox_LostFocus"/>
                        <TextBlock x:Name="EmailPlaceholder"
                                   Text="  ✉️  Email"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Username -->
                    <Grid Margin="0,0,0,12">
                        <TextBox x:Name="UsernameTextBox"
                                 Style="{StaticResource LoginTextBoxStyle}"
                                 GotFocus="UsernameTextBox_GotFocus"
                                 LostFocus="UsernameTextBox_LostFocus"/>
                        <TextBlock x:Name="UsernamePlaceholder"
                                   Text="  🆔  Tên đăng nhập"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Role -->
                    <Grid Margin="0,0,0,12">
                        <ComboBox x:Name="RoleComboBox" Height="44"
                                  FontSize="14" FontFamily="Segoe UI"
                                  Padding="12,10" SelectedIndex="0">
                            <ComboBoxItem Content="Sinh viên"/>
                            <ComboBoxItem Content="Giảng viên"/>
                        </ComboBox>
                    </Grid>

                    <!-- MSSV / Mã GV -->
                    <Grid Margin="0,0,0,12">
                        <TextBox x:Name="StudentIdTextBox"
                                 Style="{StaticResource LoginTextBoxStyle}"
                                 GotFocus="StudentIdTextBox_GotFocus"
                                 LostFocus="StudentIdTextBox_LostFocus"/>
                        <TextBlock x:Name="StudentIdPlaceholder"
                                   Text="  🎓  MSSV / Mã giảng viên"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Password -->
                    <Grid Margin="0,0,0,12">
                        <PasswordBox x:Name="PasswordBox"
                                     Style="{StaticResource LoginPasswordBoxStyle}"
                                     GotFocus="PasswordBox_GotFocus"
                                     LostFocus="PasswordBox_LostFocus"/>
                        <TextBlock x:Name="PasswordPlaceholder"
                                   Text="  🔒  Mật khẩu"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Confirm Password -->
                    <Grid Margin="0,0,0,18">
                        <PasswordBox x:Name="ConfirmPasswordBox"
                                     Style="{StaticResource LoginPasswordBoxStyle}"
                                     GotFocus="ConfirmPasswordBox_GotFocus"
                                     LostFocus="ConfirmPasswordBox_LostFocus"/>
                        <TextBlock x:Name="ConfirmPasswordPlaceholder"
                                   Text="  🔒  Xác nhận mật khẩu"
                                   Foreground="{StaticResource TextLightBrush}"
                                   FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   IsHitTestVisible="False"/>
                    </Grid>

                    <!-- Register Button -->
                    <Button x:Name="RegisterButton"
                            Content="Đăng ký"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="RegisterButton_Click"
                            Margin="0,0,0,12"/>

                    <!-- Back to Login Link -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="Đã có tài khoản? "
                                   FontSize="12" FontFamily="Segoe UI"
                                   Foreground="{StaticResource TextMediumBrush}"
                                   VerticalAlignment="Center"/>
                        <Button x:Name="LoginLink"
                                Content="Đăng nhập"
                                Style="{StaticResource LinkButtonStyle}"
                                Click="LoginLink_Click"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- ============================================ -->
        <!-- FOOTER                                       -->
        <!-- ============================================ -->
        <Border Grid.Row="2" Padding="20,8,20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="120" Height="28" FontSize="11" FontFamily="Segoe UI"
                              SelectedIndex="0" BorderThickness="1" Padding="6,3">
                        <ComboBoxItem Content="Tiếng Việt (vi)"/>
                        <ComboBoxItem Content="English (en)"/>
                    </ComboBox>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="Thông báo từ các Cookies"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextLightBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
