<Window x:Class="StudentMonitor.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thông tin Tài khoản" Height="550" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F7FA">
    
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5,0"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Avatar Section -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Border Width="100" Height="100" CornerRadius="50" BorderBrush="#1976D2" BorderThickness="2" ClipToBounds="True">
                <Image x:Name="AvatarImage" Stretch="UniformToFill" Source="/Assets/default_avatar.png" />
            </Border>
            <Button x:Name="BtnChangeAvatar" Content="Đổi ảnh đại diện" Margin="0,10,0,0" Width="120" Height="30"
                    Background="Transparent" BorderBrush="#1976D2" Foreground="#1976D2" Click="BtnChangeAvatar_Click" Cursor="Hand"/>
        </StackPanel>

        <!-- Form ScrollViewer -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="FormPanel" Margin="10">
                <TextBlock Text="Họ và Tên"/>
                <TextBox x:Name="TxtFullName" IsReadOnly="True" Background="#EEE"/>

                <StackPanel x:Name="StudentIdPanel">
                    <TextBlock Text="Mã sinh viên"/>
                    <TextBox x:Name="TxtStudentId" IsReadOnly="True" Background="#EEE"/>
                </StackPanel>

                <TextBlock Text="Quê quán"/>
                <TextBox x:Name="TxtHometown"/>

                <TextBlock Text="Địa chỉ cụ thể"/>
                <TextBox x:Name="TxtAddress"/>

                <Separator Margin="0,10,0,20"/>
                <TextBlock Text="ĐỔI MẬT KHẨU" Foreground="#1976D2" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="Mật khẩu mới"/>
                <PasswordBox x:Name="TxtNewPassword"/>

                <TextBlock Text="Xác nhận mật khẩu"/>
                <PasswordBox x:Name="TxtConfirmPassword"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="BtnCancel" Content="Hủy" Width="80" Height="35" Margin="0,0,10,0"
                    Background="#E0E0E0" BorderThickness="0" Click="BtnCancel_Click" Cursor="Hand"/>
            <Button x:Name="BtnSave" Content="Lưu thay đổi" Width="100" Height="35"
                    Background="#1976D2" Foreground="White" BorderThickness="0" Click="BtnSave_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
