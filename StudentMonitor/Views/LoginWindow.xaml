<Window x:Class="StudentMonitor.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="E-Learning - Đăng nhập"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{StaticResource BackgroundGrayBrush}">

    <Window.Resources>
        <!-- Placeholder behavior for TextBox -->
        <Style x:Key="PlaceholderTextBox" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============================================ -->
        <!-- HEADER - Blue Banner with Logo               -->
        <!-- ============================================ -->
        <Border Grid.Row="0" CornerRadius="0" Padding="0,30,0,30">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0066B3" Offset="0"/>
                    <GradientStop Color="#004C8C" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel HorizontalAlignment="Center">
                <!-- Logo Circle -->
                <Border Width="60" Height="60" CornerRadius="30"
                        Background="White" Margin="0,0,0,12"
                        HorizontalAlignment="Center">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="8" ShadowDepth="2" Opacity="0.2"/>
                    </Border.Effect>
                    <Grid>
                        <!-- Shield Icon using Path -->
                        <Viewbox Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Canvas Width="24" Height="24">
                                <!-- Shield shape -->
                                <Path Fill="#0066B3" Data="M12,1 L3,5 L3,11 C3,16.55 6.84,21.74 12,23 C17.16,21.74 21,16.55 21,11 L21,5 L12,1 Z"/>
                                <!-- Checkmark inside shield -->
                                <Path Stroke="White" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M8.5,12.5 L11,15 L16,9.5"/>
                            </Canvas>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- Title -->
                <TextBlock Text="E-Learning"
                           FontSize="26" FontWeight="Bold"
                           Foreground="White" FontFamily="Segoe UI"
                           HorizontalAlignment="Center"/>
                <!-- Subtitle -->
                <TextBlock Text="Hệ thống Học tập trực tuyến"
                           FontSize="13" Foreground="#B0D4F1"
                           FontFamily="Segoe UI"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- ============================================ -->
        <!-- CENTER - Login Form Card                     -->
        <!-- ============================================ -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Margin="50,24,50,24"
                Padding="30,28,30,24"
                VerticalAlignment="Top">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel>
                <!-- Error Message (hidden by default) -->
                <Border x:Name="ErrorBorder" Visibility="Collapsed"
                        Background="#FFF0F0" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,14"
                        BorderBrush="#FFCCCC" BorderThickness="1">
                    <TextBlock x:Name="ErrorMessage"
                               Foreground="{StaticResource ErrorRedBrush}"
                               FontSize="12" FontFamily="Segoe UI"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Success Message (hidden by default) -->
                <Border x:Name="SuccessBorder" Visibility="Collapsed"
                        Background="#F0FFF0" CornerRadius="6"
                        Padding="12,8" Margin="0,0,0,14"
                        BorderBrush="#CCFFCC" BorderThickness="1">
                    <TextBlock x:Name="SuccessMessage"
                               Foreground="{StaticResource SuccessGreenBrush}"
                               FontSize="12" FontFamily="Segoe UI"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Username field with icon -->
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="UsernameTextBox"
                             Style="{StaticResource LoginTextBoxStyle}"
                             GotFocus="UsernameTextBox_GotFocus"
                             LostFocus="UsernameTextBox_LostFocus"/>
                    
                    <!-- Placeholder -->
                    <TextBlock x:Name="UsernamePlaceholder"
                               Text="  👤  Tên đăng nhập"
                               Foreground="{StaticResource TextLightBrush}"
                               FontSize="14" FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Password field with icon -->
                <Grid Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource LoginPasswordBoxStyle}"
                                 GotFocus="PasswordBox_GotFocus"
                                 LostFocus="PasswordBox_LostFocus"/>
                    
                    <!-- Placeholder -->
                    <TextBlock x:Name="PasswordPlaceholder"
                               Text="  🔒  Mật khẩu"
                               Foreground="{StaticResource TextLightBrush}"
                               FontSize="14" FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"
                               IsHitTestVisible="False"/>
                </Grid>

                <!-- Login Button -->
                <Button x:Name="LoginButton"
                        Content="Đăng nhập"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="LoginButton_Click"
                        Margin="0,0,0,12"/>

                <!-- Register Link -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                    <TextBlock Text="Chưa có tài khoản? "
                               FontSize="12" FontFamily="Segoe UI"
                               Foreground="{StaticResource TextMediumBrush}"
                               VerticalAlignment="Center"/>
                    <Button x:Name="RegisterLink"
                            Content="Đăng ký ngay"
                            Style="{StaticResource LinkButtonStyle}"
                            Click="RegisterLink_Click"
                            FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============================================ -->
        <!-- FOOTER                                       -->
        <!-- ============================================ -->
        <Border Grid.Row="2" Padding="20,10,20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Language selector -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🌐" FontSize="13" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox Width="120" Height="28" FontSize="11" FontFamily="Segoe UI"
                              SelectedIndex="0" BorderThickness="1" Padding="6,3">
                        <ComboBoxItem Content="Tiếng Việt (vi)"/>
                        <ComboBoxItem Content="English (en)"/>
                    </ComboBox>
                </StackPanel>

                <!-- Cookie notice -->
                <TextBlock Grid.Column="1" 
                           Text="Thông báo từ các Cookies"
                           FontSize="11" FontFamily="Segoe UI"
                           Foreground="{StaticResource TextLightBrush}"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
